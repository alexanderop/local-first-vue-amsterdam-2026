{
  "name": "alexop-slidev-stack",
  "version": "1.0.0",
  "description": "Reusable Slidev theme, addon, and starter template by @alexop",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter slidev-starter dev",
    "build": "pnpm --filter slidev-starter build",
    "export": "pnpm --filter slidev-starter export",
    "typecheck": "vue-tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "keywords": [
    "slidev",
    "theme",
    "addon",
    "template"
  ],
  "author": "Alexander Opalic",
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "devDependencies": {
    "@iconify-json/ph": "^1.2.2",
    "@types/node": "^25.3.5",
    "@unocss/preset-mini": "^66.6.6",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  }
}
